# ─────────────────────────────────────────────────────────────
# Embarcadero .gitignore
# ─────────────────────────────────────────────────────────────

# ── Build output ──────────────────────────────────────────────
build/
*/build/
.Replication/
_deps/

# ── Generated experiment results & data (NEVER commit) ────────
# All benchmark/experiment output belongs in results/ (git-ignored).
# See CONTRIBUTING.md.
results/*
!results/README.md
data/
data_backup/
datathroughput/
**/result*.csv
**/baseline_*.csv
**/*_latency.csv
**/summary_*.txt
*.log

# ── Paper (kept locally, managed separately) ──────────────────
Paper/

# ── Editor / tooling ──────────────────────────────────────────
.vscode/
.idea/
tags
compile_commands.json

# ── External dependencies ─────────────────────────────────────
!third_party/
third_party/*
!third_party/CMakeLists.txt

# ── C/C++ build artifacts ─────────────────────────────────────
# https://github.com/github/gitignore/blob/main/C%2B%2B.gitignore
*.d
*.slo
*.lo
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.mod
*.smod
*.lai
*.la
*.a
*.lib
*.exe
*.out
*.app

# ── CMake artifacts ───────────────────────────────────────────
# https://github.com/github/gitignore/blob/main/CMake.gitignore
CMakeLists.txt.user
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Testing/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake

# Generated Makefiles (CMake), but keep hand-written ones that are tracked.
Makefile
!benchmarks/sequencer/Makefile
!scripts/network-emulation/Makefile
