# ─────────────────────────────────────────────────────────────
# Embarcadero .gitignore
# ─────────────────────────────────────────────────────────────

# ── Build output ──────────────────────────────────────────────
build/
*/build/
.Replication/
_deps/

# ── Generated experiment results & data (NEVER commit) ────────
# All benchmark/experiment output belongs in results/ (git-ignored).
# See CONTRIBUTING.md.
results/*
!results/README.md
# Legacy multiclient runner output; retained artifacts are exported under
# results/, never from this scratch directory.
multiclient_logs/
data/
data_backup/
datathroughput/

# Canonical paper-facing Corfu invariant summary (derived from tracked raw
# logs); keep this small provenance file versioned while all other data remain
# ignored.
!data/
data/*
!data/paper_eval/
data/paper_eval/*
!data/paper_eval/fig2/
data/paper_eval/fig2/*
!data/paper_eval/fig2/fig2_corfu_official_3eaadffb/
data/paper_eval/fig2/fig2_corfu_official_3eaadffb/*
!data/paper_eval/fig2/fig2_corfu_official_3eaadffb/corfu_invariant_summary.csv
**/result*.csv
**/baseline_*.csv
**/*_latency.csv
**/summary_*.txt
*.log

# ── Paper (kept locally, managed separately) ──────────────────
Paper/

# ── Editor / tooling ──────────────────────────────────────────
.vscode/
.idea/
tags
compile_commands.json

# ── External dependencies ─────────────────────────────────────
!third_party/
third_party/*
!third_party/CMakeLists.txt

# ── C/C++ build artifacts ─────────────────────────────────────
# https://github.com/github/gitignore/blob/main/C%2B%2B.gitignore
*.d
*.slo
*.lo
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.mod
*.smod
*.lai
*.la
*.a
*.lib
*.exe
*.out
*.app

# ── CMake artifacts ───────────────────────────────────────────
# https://github.com/github/gitignore/blob/main/CMake.gitignore
CMakeLists.txt.user
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Testing/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake

# Generated Makefiles (CMake), but keep hand-written ones that are tracked.
Makefile
!benchmarks/sequencer/Makefile
!scripts/network-emulation/Makefile

# ── Temporary / backup files ──────────────────────────────────
*.bak
*.bak_*
*.orig

# ── Python bytecode ───────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Ad-hoc session scripts dropped in repo root ───────────────
pilot_*.sh
/tmp_*.sh

# ── Leftover broker run artifacts in repo root ────────────────
/order5_anomaly_counters_broker*.csv

# Local TLA+ reproduction output.
/spec/states/
/spec/reproduced-results/
/spec/tla2tools.jar

# Accidental absolute-path artifact mirror created by legacy runners.
/home/
